# ─── Local development (SQLite + local storage) ───────────────────────────────
AUTH_SECRET=                        # npx auth secret
AUTH_URL=http://localhost:3000
DATABASE_URL="file:./dev.db"        # uses prisma/schema.prisma (SQLite)

# ─── Production (Supabase Postgres + Storage) ─────────────────────────────────
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# AUTH_URL=https://voxtome.vercel.app
# NEXTAUTH_URL=https://voxtome.vercel.app
# SUPABASE_URL=https://[ref].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# ─── Email magic link (Resend) ────────────────────────────────────────────────
# 1. Sign up at https://resend.com and create an API key
# 2. Test mode (no domain): use onboarding@resend.dev — only delivers to your Resend account email
# 3. Production: verify a domain in Resend, then set AUTH_RESEND_FROM=noreply@yourdomain.com
AUTH_RESEND_KEY=
AUTH_RESEND_FROM=onboarding@resend.dev

# ─── ElevenLabs TTS ───────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_BRITISH=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_VOICE_AMERICAN=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_NIGERIAN=            # search "nigerian" in ElevenLabs voice library

# ─── Production setup commands ────────────────────────────────────────────────
# 1. Set DATABASE_URL to your Supabase Postgres connection string
# 2. npm run db:push                   # auto-picks postgres schema when DATABASE_URL is postgres://
# 3. npm run storage:setup             # creates private "voxtome" bucket in Supabase
# 4. npm run build && npm start
# 5. Check GET /api/health for readiness